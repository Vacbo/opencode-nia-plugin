{
	"name": "@vacbo/opencode-nia-plugin",
	"version": "0.7.0",
	"description": "OpenCode plugin that integrates Nia Knowledge Agent for research and documentation",
	"type": "module",
	"main": "dist/index.js",
	"types": "dist/index.d.ts",
	"exports": {
		".": "./dist/index.js"
	},
	"bin": {
		"nia-opencode": "dist/cli.js"
	},
	"scripts": {
		"build": "tsc -p tsconfig.json",
		"dev": "tsc --watch",
		"test": "bun test",
		"test:unit": "bun test src/",
		"test:integration": "bun test tests/integration/",
		"typecheck": "tsc --noEmit -p tsconfig.json",
		"lint": "biome check --diagnostic-level=warn src/"
	},
	"keywords": [
		"opencode",
		"plugin",
		"nia",
		"knowledge",
		"research",
		"documentation",
		"ai",
		"coding-agent"
	],
	"author": "Nia",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/nozomio-labs/nia-opencode.git"
	},
	"dependencies": {
		"@opencode-ai/plugin": "1.2.27",
		"@opencode-ai/sdk": "^1.2.22",
		"commander": "^14.0.3",
		"nia-ai-ts": "0.5.0"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.8",
		"bun-types": "1.3.11",
		"typescript": "~5.8.2",
		"vitest": "^4.1.0"
	},
	"opencode": {
		"type": "plugin",
		"hooks": [
			"chat.message"
		]
	},
	"files": [
		"dist",
		"instructions"
	]
}
